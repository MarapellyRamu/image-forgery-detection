# Image Forgery Detection — Backend Environment Configuration
# Copy this file to .env and fill in your values.

# ── Security ────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a random 32+ character string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-this-secret-key-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — good for development and demo)
DATABASE_URL=sqlite:///./forgery_detection.db

# PostgreSQL (for production — uncomment and fill in your details)
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/forgery_detection

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── AI model ──────────────────────────────────────────────────────────────────
# Path to the trained fusion model (.keras file)
# Set DEMO_MODE=false and MODEL_PATH to your trained model after running train.py
MODEL_PATH=../models/saved_model/fusion_model.keras
DEMO_MODE=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000

# ── Default admin account (created on first startup) ─────────────────────────
# IMPORTANT: Change these immediately after first login!
DEFAULT_ADMIN_EMAIL=admin@forgery.ai
DEFAULT_ADMIN_PASSWORD=Admin@123
