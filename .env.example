# Backend Configuration
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./forgery_detection.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/forgery_detection

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Model
MODEL_PATH=../models/saved_model
DEMO_MODE=true

# CORS
CORSS_ORIGINS=http://localhost:3000

# Admin defaults (change immediately after first login)
DEFAULT_ADMIN_EMAIL=admin@forgery.ai
DEFAULT_ADMIN_PASSWORD=Admin@123
